import { LineEdit, SpinBox, ScrollView } from "std-widgets.slint";

export struct ProxyRow {
    index: int,
    name: string,
    local_ip: string,
    local_port: int,
    remote_port: int,
}

export struct ProxyPair {
    left: ProxyRow,
    right: ProxyRow,
    has_right: bool,
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    callback clicked();
    height: 40px;
    min-width: 132px;
    horizontal-stretch: 0;
    background: primary ? #2563eb : #ffffff;
    border-color: primary ? #2563eb : #cfd8e6;
    border-width: 1px;
    border-radius: 8px;

    Text {
        text: root.text;
        color: root.primary ? #ffffff : #172033;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 15px;
        font-weight: 700;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component InfoPill inherits Rectangle {
    in property <string> text;
    in property <color> bg: #edf4ff;
    in property <color> fg: #1d4ed8;
    height: 28px;
    min-width: 72px;
    background: bg;
    border-radius: 14px;

    Text {
        text: root.text;
        color: root.fg;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }
}

component FieldLine inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    spacing: 10px;

    Text {
        text: root.label;
        width: 64px;
        color: #64748b;
        font-size: 13px;
        font-weight: 700;
        vertical-alignment: center;
    }
    Text {
        text: root.value;
        color: #0f172a;
        font-size: 14px;
        font-weight: 700;
        vertical-alignment: center;
    }
}

component ProxyCard inherits Rectangle {
    in property <ProxyRow> item;
    height: 166px;
    background: #ffffff;
    border-color: #dbe3ee;
    border-width: 1px;
    border-radius: 10px;

    VerticalLayout {
        padding-left: 18px;
        padding-right: 18px;
        padding-top: 16px;
        padding-bottom: 14px;
        spacing: 11px;

        HorizontalLayout {
            spacing: 12px;

            Rectangle {
                width: 42px;
                height: 42px;
                background: #e0f2fe;
                border-radius: 8px;
                Text {
                    text: "tcp";
                    color: #0369a1;
                    font-size: 13px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                width: 160px;
                spacing: 4px;
                Text {
                    text: root.item.name;
                    color: #0f172a;
                    font-size: 19px;
                    font-weight: 800;
                }
                Text {
                    text: "TCP 代理 #" + root.item.index;
                    color: #64748b;
                    font-size: 13px;
                }
            }

            Rectangle { horizontal-stretch: 1; }
            InfoPill { text: "启用"; bg: #dcfce7; fg: #166534; }
        }

        Rectangle { height: 1px; background: #edf2f7; }

        VerticalLayout {
            spacing: 7px;
            FieldLine {
                label: "本地";
                value: root.item.local_ip + ":" + root.item.local_port;
            }
            FieldLine {
                label: "远端";
                value: "0.0.0.0:" + root.item.remote_port;
            }
        }
    }
}

component FormLabel inherits Text {
    color: #334155;
    font-size: 13px;
    font-weight: 800;
}

export component ProxyPage inherits Rectangle {
    in property <[ProxyPair]> proxy_pairs;
    in property <int> proxy_count;
    in-out property <bool> show_add_proxy;
    in-out property <string> add_proxy_name;
    in-out property <string> add_proxy_local_ip;
    in-out property <int> add_proxy_local_port;
    in-out property <int> add_proxy_remote_port;
    callback add_proxy(string, string, int, int);

    background: transparent;

    VerticalLayout {
        padding-left: 32px;
        padding-right: 32px;
        padding-top: 28px;
        padding-bottom: 24px;
        spacing: 18px;
        alignment: start;

        HorizontalLayout {
            spacing: 16px;
            VerticalLayout {
                spacing: 6px;
                Text { text: "代理设置"; font-size: 30px; font-weight: 800; color: #0f172a; }
                Text {
                    text: "当前仅支持 TCP 代理，保存后会刷新配置并生成 frpc.toml。";
                    color: #64748b;
                    font-size: 15px;
                    wrap: word-wrap;
                }
            }
            Rectangle { horizontal-stretch: 1; }
            ActionButton {
                text: "新增代理";
                primary: true;
                width: 132px;
                clicked => {
                    root.add_proxy_name = "tcp" + (root.proxy_count + 1);
                    root.add_proxy_local_ip = "127.0.0.1";
                    root.add_proxy_local_port = 8080;
                    root.add_proxy_remote_port = 6000;
                    root.show_add_proxy = true;
                }
            }
        }

        HorizontalLayout {
            Text { text: "代理列表"; font-size: 18px; font-weight: 800; color: #0f172a; }
            Rectangle { horizontal-stretch: 1; }
            Text { text: "共 " + root.proxy_count + " 个 TCP 代理"; color: #64748b; font-size: 14px; vertical-alignment: center; }
        }

        ScrollView {
            height: 548px;
            viewport-width: parent.width;
            viewport-height: parent.height;

            VerticalLayout {
                spacing: 14px;
                alignment: start;

                if root.proxy_pairs.length == 0 : Rectangle {
                    height: 126px;
                    background: #ffffff;
                    border-color: #dbe3ee;
                    border-width: 1px;
                    border-radius: 10px;
                    VerticalLayout {
                        padding: 20px;
                        spacing: 10px;
                        Text { text: "暂无代理"; color: #0f172a; font-size: 18px; font-weight: 800; }
                        Text { text: "点击右上角“新增代理”创建 TCP 代理。"; color: #64748b; font-size: 14px; }
                    }
                }

                for pair in root.proxy_pairs : HorizontalLayout {
                    height: 166px;
                    spacing: 14px;
                    ProxyCard { width: 342px; item: pair.left; }
                    if pair.has_right : ProxyCard { width: 342px; item: pair.right; }
                    if !pair.has_right : Rectangle { width: 342px; }
                }
            }
        }
    }

    if root.show_add_proxy: Rectangle {
        background: #0f172a66;
        x: 0px; y: 0px; width: parent.width; height: parent.height;

        Rectangle {
            width: 430px;
            height: 392px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #ffffff;
            border-color: #dbe3ee;
            border-width: 1px;
            border-radius: 10px;

            VerticalLayout {
                padding: 22px;
                spacing: 13px;
                alignment: start;

                HorizontalLayout {
                    Text { text: "新增 TCP 代理"; font-size: 22px; font-weight: 800; color: #0f172a; }
                    Rectangle { horizontal-stretch: 1; }
                    InfoPill { text: "TCP"; bg: #e0f2fe; fg: #0369a1; }
                }

                VerticalLayout {
                    spacing: 6px;
                    FormLabel { text: "代理名称"; }
                    LineEdit { text <=> root.add_proxy_name; placeholder-text: "例如 tcp1"; height: 38px; width: 386px; }
                }

                VerticalLayout {
                    spacing: 6px;
                    FormLabel { text: "本地 IP"; }
                    LineEdit { text <=> root.add_proxy_local_ip; placeholder-text: "127.0.0.1"; height: 38px; width: 386px; }
                }

                HorizontalLayout {
                    spacing: 14px;
                    VerticalLayout {
                        spacing: 6px;
                        FormLabel { text: "本地端口"; }
                        SpinBox { value <=> root.add_proxy_local_port; minimum: 1; maximum: 65535; width: 186px; height: 38px; }
                    }
                    VerticalLayout {
                        spacing: 6px;
                        FormLabel { text: "远端端口"; }
                        SpinBox { value <=> root.add_proxy_remote_port; minimum: 1; maximum: 65535; width: 186px; height: 38px; }
                    }
                }

                Rectangle { height: 4px; }

                HorizontalLayout {
                    spacing: 10px;
                    Rectangle { horizontal-stretch: 1; }
                    ActionButton {
                        text: "取消";
                        width: 96px;
                        clicked => { root.show_add_proxy = false; }
                    }
                    ActionButton {
                        text: "保存";
                        primary: true;
                        width: 104px;
                        clicked => {
                            root.add_proxy(root.add_proxy_name, root.add_proxy_local_ip, root.add_proxy_local_port, root.add_proxy_remote_port);
                            root.show_add_proxy = false;
                        }
                    }
                }
            }
        }
    }
}
