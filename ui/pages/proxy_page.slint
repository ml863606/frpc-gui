import { ScrollView } from "std-widgets.slint";

export struct ProxyRow {
    index: int,
    proxy_type: string,
    type_index: int,
    name: string,
    local_ip: string,
    local_port: int,
    remote_port: int,
    enabled: bool,
    local_test_state: int,
    remote_test_state: int,
}

export struct ProxyPair {
    left: ProxyRow,
    right: ProxyRow,
    has_right: bool,
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> danger: false;
    callback clicked();
    height: 40px;
    min-width: 132px;
    horizontal-stretch: 0;
    background: primary ? #2563eb : (danger ? #dc2626 : #ffffff);
    border-color: primary ? #2563eb : (danger ? #dc2626 : #cfd8e6);
    border-width: 1px;
    border-radius: 8px;

    Text {
        text: root.text;
        color: root.primary || root.danger ? #ffffff : #172033;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 15px;
        font-weight: 700;
    }

    TouchArea { width: parent.width; height: parent.height; clicked => { root.clicked(); } }
}

component SmallButton inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    in property <image> icon;
    callback clicked();
    height: 30px;
    horizontal-stretch: 0;
    background: danger ? #fff1f2 : #ffffff;
    border-color: danger ? #fecdd3 : #cfd8e6;
    border-width: 1px;
    border-radius: 7px;

    HorizontalLayout {
        x: 7px;
        y: 0px;
        width: parent.width - 14px;
        height: parent.height;
        spacing: 3px;
        alignment: center;

        Rectangle {
            width: 13px;
            height: parent.height;
            background: transparent;

            Image {
                x: 0px;
                y: (parent.height - self.height) / 2 + 1px;
                source: root.icon;
                width: 13px;
                height: 13px;
            }
        }

        Text {
            text: root.text;
            color: root.danger ? #be123c : #243047;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 12px;
            font-weight: 800;
        }
    }

    TouchArea { width: parent.width; height: parent.height; clicked => { root.clicked(); } }
}

component IconButton inherits Rectangle {
    in property <image> icon;
    callback clicked();
    width: 26px;
    height: 26px;
    background: touch.has-hover ? #eef5ff : #ffffff;
    border-color: #cfd8e6;
    border-width: 1px;
    border-radius: 6px;

    Image {
        x: 6px;
        y: 6px;
        width: 14px;
        height: 14px;
        source: root.icon;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component InfoPill inherits Rectangle {
    in property <string> text;
    in property <color> bg: #edf4ff;
    in property <color> fg: #1d4ed8;
    height: 28px;
    min-width: 68px;
    background: bg;
    border-radius: 14px;

    Text {
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.text;
        color: root.fg;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 700;
    }
}

component TestMark inherits Rectangle {
    in property <int> state;
    width: 30px;
    height: 38px;
    background: transparent;

    if root.state == 1 : Text {
        text: "...";
        color: #2563eb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 900;
    }

    if root.state == 2 : Image {
        x: 3px;
        y: 7px;
        width: 24px;
        height: 24px;
        source: @image-url("../../resources/icons/check.svg");
    }

    if root.state == 3 : Image {
        x: 3px;
        y: 7px;
        width: 24px;
        height: 24px;
        source: @image-url("../../resources/icons/x.svg");
    }
}

component InlineTestMark inherits Rectangle {
    in property <int> state;
    width: 20px;
    height: 26px;
    background: transparent;

    if root.state == 1 : Text {
        text: "...";
        color: #2563eb;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 11px;
        font-weight: 900;
    }

    if root.state == 2 : Image {
        x: 2px;
        y: 5px;
        width: 16px;
        height: 16px;
        source: @image-url("../../resources/icons/check.svg");
    }

    if root.state == 3 : Image {
        x: 2px;
        y: 5px;
        width: 16px;
        height: 16px;
        source: @image-url("../../resources/icons/x.svg");
    }
}

component TypeOption inherits Rectangle {
    in-out property <int> selected_index;
    in property <int> option_index;
    in property <string> label;
    height: 34px;
    background: root.selected_index == root.option_index ? #2563eb : transparent;
    border-radius: 7px;

    Text {
        text: root.label;
        color: root.selected_index == root.option_index ? #ffffff : #334155;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 800;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.selected_index = root.option_index;
        }
    }
}

component FormLabel inherits Text {
    color: #334155;
    font-size: 13px;
    font-weight: 800;
}

component StyledTextField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    height: 38px;
    background: #f8fafc;
    border-color: input.has-focus ? #2563eb : #cbd5e1;
    border-width: 1px;
    border-radius: 8px;

    Text {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.placeholder;
        color: #94a3b8;
        font-size: 14px;
        vertical-alignment: center;
        visible: root.text == "" && !input.has-focus;
    }

    input := TextInput {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text <=> root.text;
        color: #0f172a;
        font-size: 14px;
        vertical-alignment: center;
    }
}

component InputShell inherits Rectangle {
    height: 40px;
    background: #f8fafc;
    border-color: #cbd5e1;
    border-width: 1px;
    border-radius: 8px;
}

component FieldLine inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    in property <int> test_state;
    spacing: 8px;

    HorizontalLayout {
        width: 52px;
        height: 26px;
        spacing: 2px;
        Text {
            text: root.label;
            width: 30px;
            color: #64748b;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }
        InlineTestMark { state: root.test_state; }
    }
    Text {
        text: root.value;
        horizontal-stretch: 1;
        color: #0f172a;
        font-size: 14px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }
}

component RemoteFieldLine inherits HorizontalLayout {
    in property <string> host;
    in property <int> port;
    in property <int> test_state;
    callback copy();
    callback open();
    spacing: 8px;

    HorizontalLayout {
        width: 52px;
        height: 26px;
        spacing: 2px;
        Text {
            text: "远端";
            width: 30px;
            color: #64748b;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }
        InlineTestMark { state: root.test_state; }
    }
    Text {
        text: (root.host == "" ? "未配置" : root.host) + ":" + root.port;
        horizontal-stretch: 1;
        color: root.host == "" ? #94a3b8 : #0f172a;
        font-size: 14px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }
    IconButton {
        icon: @image-url("../../resources/icons/copy.svg");
        clicked => { root.copy(); }
    }
    IconButton {
        icon: @image-url("../../resources/icons/external-link.svg");
        clicked => { root.open(); }
    }
}

component ProxyCard inherits Rectangle {
    in property <ProxyRow> item;
    in property <string> remote_host;
    callback edit(int);
    callback remove(int);
    callback clone(int);
    callback toggle(int);
    callback test(int);
    callback copy_remote(string, int);
    callback open_remote(string, int, string);
    height: 182px;
    background: root.item.enabled ? #ffffff : #f8fafc;
    border-color: root.item.enabled ? #dbe3ee : #cbd5e1;
    border-width: 1px;
    border-radius: 10px;

    VerticalLayout {
        padding-left: 18px;
        padding-right: 18px;
        padding-top: 16px;
        padding-bottom: 8px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 10px;

            Rectangle {
                width: 42px;
                height: 42px;
                background: root.item.proxy_type == "TCP" ? #e0f2fe : (root.item.proxy_type == "UDP" ? #fef3c7 : #eef5ff);
                border-radius: 8px;
                Text {
                    text: root.item.proxy_type;
                    color: root.item.proxy_type == "TCP" ? #0369a1 : (root.item.proxy_type == "UDP" ? #92400e : #1d4ed8);
                    font-size: root.item.proxy_type == "HTTPS" ? 10px : 12px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                width: 140px;
                spacing: 4px;
                Text { text: root.item.name; color: #0f172a; font-size: 19px; font-weight: 800; }
                Text { text: root.item.proxy_type + " 代理 #" + root.item.index; color: #64748b; font-size: 13px; }
            }

            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                width: 70px;
                height: 28px;
                background: transparent;

                InfoPill {
                    width: parent.width;
                    text: root.item.enabled ? "已启用" : "已停用";
                    bg: status_touch.has-hover
                        ? (root.item.enabled ? #bbf7d0 : #cbd5e1)
                        : (root.item.enabled ? #dcfce7 : #e2e8f0);
                    fg: root.item.enabled ? #166534 : #475569;
                }

                status_touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { root.toggle(root.item.index); }
                }
            }
        }

        Rectangle { height: 1px; background: #edf2f7; }

        VerticalLayout {
            spacing: 7px;
            FieldLine {
                label: "本地";
                value: root.item.local_ip + ":" + root.item.local_port;
                test_state: root.item.local_test_state;
            }
            RemoteFieldLine {
                host: root.remote_host;
                port: root.item.remote_port;
                test_state: root.item.remote_test_state;
                copy => { root.copy_remote(root.remote_host, root.item.remote_port); }
                open => { root.open_remote(root.remote_host, root.item.remote_port, root.item.proxy_type); }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Rectangle { horizontal-stretch: 1; }
            SmallButton {
                text: "克隆";
                icon: @image-url("../../resources/icons/copy.svg");
                width: 58px;
                clicked => { root.clone(root.item.index); }
            }
            SmallButton {
                text: "测试";
                icon: @image-url("../../resources/icons/plug.svg");
                width: 58px;
                clicked => { root.test(root.item.index); }
            }
            SmallButton {
                text: "编辑";
                icon: @image-url("../../resources/icons/edit.svg");
                width: 58px;
                clicked => { root.edit(root.item.index); }
            }
            SmallButton {
                text: "删除";
                danger: true;
                icon: @image-url("../../resources/icons/trash.svg");
                width: 58px;
                clicked => { root.remove(root.item.index); }
            }
        }
    }
}

component ProxyForm inherits Rectangle {
    in property <string> title;
    in property <string> badge;
    in-out property <int> type_index;
    in-out property <string> name;
    in-out property <string> local_ip;
    in-out property <string> local_port_text;
    in-out property <string> remote_port_text;
    in property <int> local_test_state;
    in property <int> remote_test_state;
    callback cancel();
    callback save();
    callback test();

    width: 430px;
    height: 454px;
    background: #ffffff;
    border-color: #dbe3ee;
    border-width: 1px;
    border-radius: 10px;

    VerticalLayout {
        padding: 22px;
        spacing: 13px;
        alignment: start;

        HorizontalLayout {
            Text { text: root.title; font-size: 22px; font-weight: 800; color: #0f172a; }
            Rectangle { horizontal-stretch: 1; }
            InfoPill { text: root.badge; bg: #e0f2fe; fg: #0369a1; }
        }

        VerticalLayout {
            spacing: 6px;
            FormLabel { text: "代理类型"; }
            InputShell {
                width: 386px;
                HorizontalLayout {
                    x: 3px;
                    y: 3px;
                    width: parent.width - 6px;
                    height: parent.height - 6px;
                    spacing: 4px;
                    TypeOption { width: 91px; selected_index <=> root.type_index; option_index: 0; label: "TCP"; }
                    TypeOption { width: 91px; selected_index <=> root.type_index; option_index: 1; label: "UDP"; }
                    TypeOption { width: 91px; selected_index <=> root.type_index; option_index: 2; label: "HTTP"; }
                    TypeOption { width: 91px; selected_index <=> root.type_index; option_index: 3; label: "HTTPS"; }
                }
            }
        }

        VerticalLayout {
            spacing: 6px;
            FormLabel { text: "代理名称"; }
            StyledTextField { text <=> root.name; placeholder: "例如 tcp1"; width: 386px; }
        }

        VerticalLayout {
            spacing: 6px;
            FormLabel { text: "本地 IP"; }
            StyledTextField { text <=> root.local_ip; placeholder: "127.0.0.1"; width: 386px; }
        }

        HorizontalLayout {
            width: 386px;
            spacing: 18px;
            VerticalLayout {
                width: 184px;
                spacing: 6px;
                FormLabel { text: "本地端口"; }
                HorizontalLayout {
                    spacing: 6px;
                    StyledTextField { text <=> root.local_port_text; placeholder: "8080"; width: 78px; }
                    TestMark { state: root.local_test_state; }
                }
            }
            VerticalLayout {
                width: 184px;
                spacing: 6px;
                FormLabel { text: "远端端口"; }
                HorizontalLayout {
                    spacing: 6px;
                    StyledTextField { text <=> root.remote_port_text; placeholder: "6000"; width: 78px; }
                    TestMark { state: root.remote_test_state; }
                }
            }
        }

        Rectangle { height: 4px; }

        HorizontalLayout {
            spacing: 10px;
            Rectangle { horizontal-stretch: 1; }
            ActionButton { text: "取消"; width: 96px; clicked => { root.cancel(); } }
            ActionButton { text: "测试"; width: 96px; clicked => { root.test(); } }
            ActionButton { text: "保存"; primary: true; width: 104px; clicked => { root.save(); } }
        }
    }
}

export component ProxyPage inherits Rectangle {
    in property <[ProxyPair]> proxy_pairs;
    in property <int> proxy_count;
    in property <string> frps_public_ip;
    in-out property <bool> copy_feedback_visible: false;
    property <bool> show_delete_confirm: false;
    property <int> delete_proxy_index: 0;
    property <string> delete_proxy_name: "";
    in-out property <bool> show_add_proxy;
    in-out property <int> add_proxy_type_index;
    in-out property <string> add_proxy_name;
    in-out property <string> add_proxy_local_ip;
    in-out property <string> add_proxy_local_port_text;
    in-out property <string> add_proxy_remote_port_text;
    in-out property <int> add_proxy_local_test_state;
    in-out property <int> add_proxy_remote_test_state;
    in-out property <bool> show_edit_proxy;
    in-out property <int> edit_proxy_index;
    in-out property <int> edit_proxy_type_index;
    in-out property <string> edit_proxy_name;
    in-out property <string> edit_proxy_local_ip;
    in-out property <string> edit_proxy_local_port_text;
    in-out property <string> edit_proxy_remote_port_text;
    in-out property <int> edit_proxy_local_test_state;
    in-out property <int> edit_proxy_remote_test_state;
    callback add_proxy(int, string, string, string, string);
    callback edit_proxy(int, int, string, string, string, string);
    callback clone_proxy(int);
    callback delete_proxy(int);
    callback toggle_proxy(int);
    callback test_proxy(int);
    callback test_proxy_input(int, string, string, string);
    callback copy_remote_address(string, int);
    callback open_remote_address(string, int, string);

    background: transparent;

    VerticalLayout {
        padding-left: 32px;
        padding-right: 32px;
        padding-top: 28px;
        padding-bottom: 24px;
        spacing: 18px;
        alignment: start;

        HorizontalLayout {
            spacing: 16px;
            VerticalLayout {
                spacing: 6px;
                Text { text: "代理设置"; font-size: 30px; font-weight: 800; color: #0f172a; }
                Text { text: "支持 TCP / UDP / HTTP / HTTPS 代理，保存后刷新配置并生成 frpc.toml。"; color: #64748b; font-size: 15px; wrap: word-wrap; }
            }
            Rectangle { horizontal-stretch: 1; }
            ActionButton {
                text: "新增代理";
                primary: true;
                width: 132px;
                clicked => {
                    root.add_proxy_type_index = 0;
                    root.add_proxy_name = "tcp" + (root.proxy_count + 1);
                    root.add_proxy_local_ip = "127.0.0.1";
                    root.add_proxy_local_port_text = "8080";
                    root.add_proxy_remote_port_text = "6000";
                    root.add_proxy_local_test_state = 0;
                    root.add_proxy_remote_test_state = 0;
                    root.show_add_proxy = true;
                }
            }
        }

        HorizontalLayout {
            Text { text: "代理列表"; font-size: 18px; font-weight: 800; color: #0f172a; }
            Rectangle { horizontal-stretch: 1; }
            Text { text: "共 " + root.proxy_count + " 个代理"; color: #64748b; font-size: 14px; vertical-alignment: center; }
        }

        ScrollView {
            height: 548px;
            viewport-width: parent.width;
            viewport-height: parent.height;

            VerticalLayout {
                spacing: 14px;
                alignment: start;

                if root.proxy_pairs.length == 0 : Rectangle {
                    height: 126px;
                    background: #ffffff;
                    border-color: #dbe3ee;
                    border-width: 1px;
                    border-radius: 10px;
                    VerticalLayout {
                        padding: 20px;
                        spacing: 10px;
                        Text { text: "暂无代理"; color: #0f172a; font-size: 18px; font-weight: 800; }
                        Text { text: "点击右上角“新增代理”创建代理。"; color: #64748b; font-size: 14px; }
                    }
                }

                for pair in root.proxy_pairs : HorizontalLayout {
                    height: 182px;
                    spacing: 14px;
                    ProxyCard {
                        width: 342px;
                        item: pair.left;
                        remote_host: root.frps_public_ip;
                        edit(index) => {
                            root.edit_proxy_index = index;
                            root.edit_proxy_type_index = pair.left.type_index;
                            root.edit_proxy_name = pair.left.name;
                            root.edit_proxy_local_ip = pair.left.local_ip;
                            root.edit_proxy_local_port_text = "" + pair.left.local_port;
                            root.edit_proxy_remote_port_text = "" + pair.left.remote_port;
                            root.edit_proxy_local_test_state = 0;
                            root.edit_proxy_remote_test_state = 0;
                            root.show_edit_proxy = true;
                        }
                        remove(index) => {
                            root.delete_proxy_index = index;
                            root.delete_proxy_name = pair.left.name;
                            root.show_delete_confirm = true;
                        }
                        clone(index) => { root.clone_proxy(index); }
                        toggle(index) => { root.toggle_proxy(index); }
                        test(index) => { root.test_proxy(index); }
                        copy_remote(host, port) => {
                            root.copy_remote_address(host, port);
                            if host != "" { root.copy_feedback_visible = true; }
                        }
                        open_remote(host, port, proxy_type) => { root.open_remote_address(host, port, proxy_type); }
                    }
                    if pair.has_right : ProxyCard {
                        width: 342px;
                        item: pair.right;
                        remote_host: root.frps_public_ip;
                        edit(index) => {
                            root.edit_proxy_index = index;
                            root.edit_proxy_type_index = pair.right.type_index;
                            root.edit_proxy_name = pair.right.name;
                            root.edit_proxy_local_ip = pair.right.local_ip;
                            root.edit_proxy_local_port_text = "" + pair.right.local_port;
                            root.edit_proxy_remote_port_text = "" + pair.right.remote_port;
                            root.edit_proxy_local_test_state = 0;
                            root.edit_proxy_remote_test_state = 0;
                            root.show_edit_proxy = true;
                        }
                        remove(index) => {
                            root.delete_proxy_index = index;
                            root.delete_proxy_name = pair.right.name;
                            root.show_delete_confirm = true;
                        }
                        clone(index) => { root.clone_proxy(index); }
                        toggle(index) => { root.toggle_proxy(index); }
                        test(index) => { root.test_proxy(index); }
                        copy_remote(host, port) => {
                            root.copy_remote_address(host, port);
                            if host != "" { root.copy_feedback_visible = true; }
                        }
                        open_remote(host, port, proxy_type) => { root.open_remote_address(host, port, proxy_type); }
                    }
                    if !pair.has_right : Rectangle { width: 342px; }
                }
            }
        }
    }

    Timer {
        interval: 1600ms;
        running: root.copy_feedback_visible;
        triggered => { root.copy_feedback_visible = false; }
    }

    if root.copy_feedback_visible : Rectangle {
        x: (parent.width - self.width) / 2;
        y: 20px;
        width: 116px;
        height: 38px;
        background: #166534;
        border-radius: 8px;

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            spacing: 7px;
            alignment: center;

            Rectangle {
                width: 18px;
                height: parent.height;
                background: transparent;

                Image {
                    x: 0px;
                    y: (parent.height - self.height) / 2;
                    width: 18px;
                    height: 18px;
                    source: @image-url("../../resources/icons/check.svg");
                }
            }
            Text {
                text: "已复制";
                color: #ffffff;
                font-size: 14px;
                font-weight: 800;
                vertical-alignment: center;
            }
        }
    }

    if root.show_delete_confirm : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0f172a66;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.show_delete_confirm = false; }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 380px;
            height: 210px;
            background: #ffffff;
            border-color: #dbe3ee;
            border-width: 1px;
            border-radius: 8px;

            VerticalLayout {
                padding: 22px;
                spacing: 16px;

                HorizontalLayout {
                    spacing: 12px;

                    Rectangle {
                        width: 42px;
                        height: 42px;
                        background: #fee2e2;
                        border-radius: 8px;

                        Image {
                            x: 11px;
                            y: 11px;
                            width: 20px;
                            height: 20px;
                            source: @image-url("../../resources/icons/trash.svg");
                        }
                    }

                    VerticalLayout {
                        spacing: 3px;
                        Text { text: "删除代理"; color: #0f172a; font-size: 20px; font-weight: 800; }
                        Text { text: root.delete_proxy_name; color: #64748b; font-size: 13px; overflow: elide; }
                    }
                }

                Text {
                    text: "删除后无法恢复，确认删除这个代理吗？";
                    color: #475569;
                    font-size: 14px;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 10px;
                    Rectangle { horizontal-stretch: 1; }
                    ActionButton {
                        text: "取消";
                        width: 104px;
                        clicked => { root.show_delete_confirm = false; }
                    }
                    ActionButton {
                        text: "确认删除";
                        danger: true;
                        width: 112px;
                        clicked => {
                            root.show_delete_confirm = false;
                            root.delete_proxy(root.delete_proxy_index);
                        }
                    }
                }
            }
        }
    }

    if root.show_add_proxy: Rectangle {
        background: #0f172a66;
        x: 0px; y: 0px; width: parent.width; height: parent.height;

        ProxyForm {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            title: "新增代理";
            badge: "TCP";
            type_index <=> root.add_proxy_type_index;
            name <=> root.add_proxy_name;
            local_ip <=> root.add_proxy_local_ip;
            local_port_text <=> root.add_proxy_local_port_text;
            remote_port_text <=> root.add_proxy_remote_port_text;
            local_test_state: root.add_proxy_local_test_state;
            remote_test_state: root.add_proxy_remote_test_state;
            cancel => { root.show_add_proxy = false; }
            test => {
                root.add_proxy_local_test_state = 1;
                root.add_proxy_remote_test_state = 1;
                root.test_proxy_input(0, root.add_proxy_local_ip, root.add_proxy_local_port_text, root.add_proxy_remote_port_text);
            }
            save => {
                root.add_proxy(root.add_proxy_type_index, root.add_proxy_name, root.add_proxy_local_ip, root.add_proxy_local_port_text, root.add_proxy_remote_port_text);
                root.show_add_proxy = false;
            }
        }
    }

    if root.show_edit_proxy: Rectangle {
        background: #0f172a66;
        x: 0px; y: 0px; width: parent.width; height: parent.height;

        ProxyForm {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            title: "编辑代理";
            badge: "#" + root.edit_proxy_index;
            type_index <=> root.edit_proxy_type_index;
            name <=> root.edit_proxy_name;
            local_ip <=> root.edit_proxy_local_ip;
            local_port_text <=> root.edit_proxy_local_port_text;
            remote_port_text <=> root.edit_proxy_remote_port_text;
            local_test_state: root.edit_proxy_local_test_state;
            remote_test_state: root.edit_proxy_remote_test_state;
            cancel => { root.show_edit_proxy = false; }
            test => {
                root.edit_proxy_local_test_state = 1;
                root.edit_proxy_remote_test_state = 1;
                root.test_proxy_input(1, root.edit_proxy_local_ip, root.edit_proxy_local_port_text, root.edit_proxy_remote_port_text);
            }
            save => {
                root.edit_proxy(root.edit_proxy_index, root.edit_proxy_type_index, root.edit_proxy_name, root.edit_proxy_local_ip, root.edit_proxy_local_port_text, root.edit_proxy_remote_port_text);
                root.show_edit_proxy = false;
            }
        }
    }
}
