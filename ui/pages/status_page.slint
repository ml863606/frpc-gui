component ActionButton inherits Rectangle {
    in property <string> text;
    in property <image> icon;
    in property <bool> primary: false;
    in property <bool> danger: false;
    callback clicked();
    height: 62px;
    min-width: 220px;
    horizontal-stretch: 0;
    background: danger ? #dc2626 : (primary ? #16a34a : #ffffff);
    border-color: danger ? #dc2626 : (primary ? #16a34a : #cfd8e6);
    border-width: 1px;
    border-radius: 12px;

    HorizontalLayout {
        x: 18px;
        width: parent.width - 36px;
        height: parent.height;
        spacing: 9px;
        alignment: center;

        Rectangle {
            width: 22px;
            height: parent.height;
            background: transparent;
            Image {
                x: 0px;
                y: (parent.height - self.height) / 2;
                width: 22px;
                height: 22px;
                source: root.icon;
            }
        }
        Text {
            text: root.text;
            color: (root.primary || root.danger) ? #ffffff : #172033;
            vertical-alignment: center;
            font-size: 20px;
            font-weight: 800;
        }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component MetricCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <image> icon;
    in property <length> card_width: 220px;
    in property <length> value_font_size: 22px;
    in property <color> bg: #ffffff;
    in property <color> border: #dbe3ee;
    in property <color> value_color: #0f172a;
    width: card_width;
    height: 104px;
    background: bg;
    border-color: border;
    border-width: 1px;
    border-radius: 10px;

    VerticalLayout {
        padding: 14px;
        spacing: 7px;
        alignment: center;

        HorizontalLayout {
            height: 22px;
            spacing: 7px;

            Rectangle {
                width: 22px;
                height: parent.height;
                background: transparent;
                Image {
                    x: 0px;
                    y: (parent.height - self.height) / 2;
                    width: 22px;
                    height: 22px;
                    source: root.icon;
                }
            }
            Text {
                text: root.label;
                color: #64748b;
                font-size: 13px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.value;
            width: parent.width - 28px;
            font-size: root.value_font_size;
            font-weight: 800;
            color: root.value_color;
            overflow: elide;
        }
    }
}

export component StatusPage inherits Rectangle {
    in property <string> status_text;
    in property <int> service_state;
    in property <string> selected_version;
    in property <string> frps_public_ip;
    in property <int> frps_port;
    in property <int> active_proxy_count;
    in property <string> active_proxy_names;
    callback start_service();
    callback stop_service();

    background: transparent;

    VerticalLayout {
        padding-left: 32px;
        padding-right: 32px;
        padding-top: 28px;
        padding-bottom: 24px;
        spacing: 18px;
        alignment: start;

        HorizontalLayout {
            spacing: 16px;
            VerticalLayout {
                spacing: 6px;
                Text { text: "运行状态"; font-size: 30px; font-weight: 800; color: #0f172a; }
                Text { text: "启动或停止 frp 代理服务，状态颜色会反映当前运行结果。"; color: #64748b; font-size: 15px; }
            }
            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                width: 220px;
                height: 32px;
                background: root.service_state == 1 ? #dcfce7 : (root.service_state == 2 ? #fee2e2 : #f1f5f9);
                border-radius: 16px;
                Text {
                    text: root.status_text;
                    color: root.service_state == 1 ? #166534 : (root.service_state == 2 ? #991b1b : #475569);
                    font-size: 14px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        HorizontalLayout {
            spacing: 14px;
            MetricCard {
                label: "服务状态";
                value: root.status_text;
                icon: @image-url("../../resources/status-icons/service.svg");
                card_width: 250px;
                bg: root.service_state == 1 ? #f0fdf4 : (root.service_state == 2 ? #fef2f2 : #ffffff);
                border: root.service_state == 1 ? #86efac : (root.service_state == 2 ? #fecaca : #dbe3ee);
                value_color: root.service_state == 1 ? #166534 : (root.service_state == 2 ? #991b1b : #475569);
                value_font_size: root.service_state == 1 ? 18px : 22px;
            }
            MetricCard {
                label: "当前版本";
                value: root.selected_version;
                icon: @image-url("../../resources/status-icons/version.svg");
                card_width: 160px;
            }
            MetricCard {
                label: "frps";
                value: (root.frps_public_ip == "" ? "未配置" : root.frps_public_ip) + ":" + root.frps_port;
                icon: @image-url("../../resources/status-icons/server.svg");
                card_width: 286px;
                value_font_size: 18px;
            }
        }

        Rectangle {
            height: 104px;
            background: #ffffff;
            border-color: root.service_state == 1 ? #bfdbfe : #dbe3ee;
            border-width: 1px;
            border-radius: 10px;

            HorizontalLayout {
                padding: 16px;
                spacing: 18px;

                VerticalLayout {
                    width: 180px;
                    spacing: 6px;
                    alignment: center;

                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            background: root.service_state == 1 ? #dbeafe : #e2e8f0;
                            border-radius: 7px;
                            Image {
                                x: 4px;
                                y: 4px;
                                width: 20px;
                                height: 20px;
                                source: @image-url("../../resources/status-icons/proxy.svg");
                            }
                        }
                        Text {
                            text: "正在代理";
                            color: #64748b;
                            font-size: 14px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Text {
                        text: root.active_proxy_count + " 个服务";
                        color: root.service_state == 1 ? #1d4ed8 : #475569;
                        font-size: 22px;
                        font-weight: 800;
                    }
                }

                Rectangle { width: 1px; background: #e2e8f0; }

                VerticalLayout {
                    spacing: 7px;
                    Text { text: "服务名称"; color: #64748b; font-size: 14px; font-weight: 700; }
                    Text {
                        text: root.active_proxy_names;
                        height: 48px;
                        color: #0f172a;
                        font-size: 15px;
                        font-weight: 800;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }
            }
        }

        Rectangle {
            height: 112px;
            background: #ffffff;
            border-color: #dbe3ee;
            border-width: 1px;
            border-radius: 10px;

            HorizontalLayout {
                padding: 18px;
                Rectangle { horizontal-stretch: 1; }
                if root.service_state == 1 : ActionButton {
                    text: "停止服务";
                    icon: @image-url("../../resources/status-icons/power.svg");
                    danger: true;
                    width: 240px;
                    clicked => { root.stop_service(); }
                }
                if root.service_state != 1 : ActionButton {
                    text: root.service_state == 1 ? "停止服务" : (root.service_state == 2 ? "重新启动服务" : "启动服务");
                    icon: @image-url("../../resources/status-icons/power.svg");
                    primary: true;
                    width: 240px;
                    clicked => { root.start_service(); }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }
    }
}
