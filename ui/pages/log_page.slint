import { ScrollView } from "std-widgets.slint";

component ActionButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    height: 34px;
    width: 112px;
    background: #ffffff;
    border-color: #cfd8e6;
    border-width: 1px;
    border-radius: 7px;

    Text {
        text: root.text;
        color: #243047;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 13px;
        font-weight: 800;
    }

    TouchArea { width: parent.width; height: parent.height; clicked => { root.clicked(); } }
}

component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked();
    height: 38px;
    width: 156px;
    background: active ? #2563eb : #ffffff;
    border-color: active ? #2563eb : #cfd8e6;
    border-width: 1px;
    border-radius: 8px;

    Text {
        text: root.text;
        color: root.active ? #ffffff : #243047;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 14px;
        font-weight: 800;
    }

    TouchArea { width: parent.width; height: parent.height; clicked => { root.clicked(); } }
}

export component LogPage inherits Rectangle {
    in-out property <int> current_tab;
    in property <string> app_log_text;
    in property <string> frpc_log_text;
    callback clear_current_log(int);

    background: #f4f7fb;

    VerticalLayout {
        padding-left: 32px;
        padding-right: 32px;
        padding-top: 28px;
        padding-bottom: 24px;
        spacing: 18px;
        alignment: start;

        HorizontalLayout {
            spacing: 16px;
            VerticalLayout {
                spacing: 6px;
                Text { text: "日志界面"; font-size: 30px; font-weight: 800; color: #0f172a; }
                Text { text: "通过 Tab 切换 exe 操作日志和 frpc 输出日志。"; color: #64748b; font-size: 15px; }
            }
            Rectangle { horizontal-stretch: 1; }
            ActionButton {
                text: "清空当前";
                clicked => { root.clear_current_log(root.current_tab); }
            }
        }

        Rectangle {
            height: 64px;
            background: #ffffff;
            border-color: #dbe3ee;
            border-width: 1px;
            border-radius: 10px;

            HorizontalLayout {
                padding: 13px;
                spacing: 10px;
                TabButton {
                    text: "exe 操作日志";
                    active: root.current_tab == 0;
                    clicked => { root.current_tab = 0; }
                }
                TabButton {
                    text: "frpc 自带日志";
                    active: root.current_tab == 1;
                    clicked => { root.current_tab = 1; }
                }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: root.current_tab == 0 ? "下载、同步、配置、连通性" : "frpc stdout / stderr";
                    color: #64748b;
                    font-size: 13px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 488px;
            background: #ffffff;
            border-color: #dbe3ee;
            border-width: 1px;
            border-radius: 10px;

            log-scroll := ScrollView {
                x: 12px;
                y: 12px;
                width: parent.width - 24px;
                height: parent.height - 24px;
                viewport-width: self.visible-width;
                viewport-height: max(self.visible-height, log-input.preferred-height);

                log-input := TextInput {
                    text: (root.current_tab == 0 ? root.app_log_text : root.frpc_log_text) == "" ? "暂无日志" : (root.current_tab == 0 ? root.app_log_text : root.frpc_log_text);
                    color: (root.current_tab == 0 ? root.app_log_text : root.frpc_log_text) == "" ? #94a3b8 : #111827;
                    font-size: 13px;
                    font-family: "Consolas";
                    read-only: true;
                    single-line: false;
                    wrap: word-wrap;
                    selection-background-color: #bfdbfe;
                    selection-foreground-color: #0f172a;
                    page-height: log-scroll.visible-height;
                }
            }
        }
    }
}
