component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <int> state: 0;
    callback clicked();
    height: 40px;
    min-width: 112px;
    horizontal-stretch: 0;
    background: primary ? #2563eb : (state == 2 ? #f0fdf4 : (state == 3 ? #fef2f2 : #ffffff));
    border-color: primary ? #2563eb : (state == 2 ? #86efac : (state == 3 ? #fecaca : #cfd8e6));
    border-width: 1px;
    border-radius: 8px;

    Text {
        text: root.text;
        x: root.state == 2 || root.state == 3 ? 28px : 0px;
        width: parent.width - (root.state == 2 || root.state == 3 ? 32px : 0px);
        color: root.primary ? #ffffff : (root.state == 2 ? #166534 : (root.state == 3 ? #991b1b : #172033));
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 15px;
        font-weight: 700;
    }

    if root.state == 2 : Image {
        x: 8px;
        y: 11px;
        width: 18px;
        height: 18px;
        source: @image-url("../../resources/icons/check.svg");
    }

    if root.state == 3 : Image {
        x: 8px;
        y: 11px;
        width: 18px;
        height: 18px;
        source: @image-url("../../resources/icons/x.svg");
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component SegmentButton inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked();
    height: 36px;
    background: active ? #2563eb : #ffffff;
    border-color: active ? #2563eb : #d7dee8;
    border-width: 1px;
    border-radius: 7px;

    Text {
        text: root.text;
        color: root.active ? #ffffff : #334155;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 14px;
        font-weight: 800;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component FormLabel inherits Text {
    color: #334155;
    font-size: 13px;
    font-weight: 800;
}

component FieldGroup inherits VerticalLayout {
    in property <string> label;
    spacing: 7px;
    FormLabel { text: root.label; }
}

component StyledTextField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    height: 38px;
    background: #f8fafc;
    border-color: input.has-focus ? #2563eb : #cbd5e1;
    border-width: 1px;
    border-radius: 8px;

    Text {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.placeholder;
        color: #94a3b8;
        font-size: 14px;
        vertical-alignment: center;
        visible: root.text == "" && !input.has-focus;
    }

    input := TextInput {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text <=> root.text;
        color: #0f172a;
        font-size: 14px;
        vertical-alignment: center;
    }
}

export component FrpsPage inherits Rectangle {
    in-out property <string> frps_public_ip;
    in-out property <int> frps_port;
    in-out property <string> frps_port_text;
    in property <string> connection_test_status;
    in property <bool> connection_testing;
    in property <int> connection_test_state;
    in-out property <bool> save_feedback_visible: false;
    in-out property <int> auth_method_index;
    in-out property <string> auth_token;
    callback save_frps();
    callback test_frps_connection();

    background: transparent;

    VerticalLayout {
        padding-left: 32px;
        padding-right: 32px;
        padding-top: 28px;
        padding-bottom: 24px;
        spacing: 18px;
        alignment: start;

        VerticalLayout {
            spacing: 6px;
            Text { text: "frps设置"; font-size: 30px; font-weight: 800; color: #0f172a; }
            Text {
                text: "设置公网 frps 入口和鉴权方式。";
                color: #64748b;
                font-size: 15px;
                wrap: word-wrap;
            }
        }

        Rectangle { width: 640px; height: 1px; background: #dbe3ee; }

        VerticalLayout {
            width: 640px;
            spacing: 15px;
            alignment: start;

            HorizontalLayout {
                spacing: 12px;

                FieldGroup {
                    width: root.width >= 760px ? 160px : 120px;
                    label: "公网 IP / 域名";
                    StyledTextField {
                        width: parent.width;
                        text <=> root.frps_public_ip;
                        placeholder: "例如 1.2.3.4 或 frps.example.com";
                    }
                }

                FieldGroup {
                    width: 110px;
                    label: "服务端端口";
                    StyledTextField {
                        width: 110px;
                        text <=> root.frps_port_text;
                        placeholder: "7000";
                    }
                }

                VerticalLayout {
                    width: 130px;
                    spacing: 7px;
                    Rectangle { height: 16px; background: transparent; }
                    ActionButton {
                        width: 130px;
                        text: root.connection_testing ? "测试中..." : "测试连通性";
                        state: root.connection_test_state;
                        clicked => { root.test_frps_connection(); }
                    }
                }
            }

            FieldGroup {
                width: 640px;
                label: "鉴权方式";
                HorizontalLayout {
                    spacing: 8px;
                    SegmentButton {
                        text: "无鉴权";
                        active: root.auth_method_index == 0;
                        width: 112px;
                        clicked => { root.auth_method_index = 0; }
                    }
                    SegmentButton {
                        text: "token";
                        active: root.auth_method_index == 1;
                        width: 112px;
                        clicked => { root.auth_method_index = 1; }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }

            if root.auth_method_index == 1 : FieldGroup {
                width: 386px;
                label: "Token";
                StyledTextField {
                    width: 386px;
                    text <=> root.auth_token;
                    placeholder: "输入 frps token";
                }
            }

            Rectangle { width: 640px; height: 1px; background: #dbe3ee; }

            HorizontalLayout {
                width: 640px;
                Rectangle { horizontal-stretch: 1; }
                ActionButton {
                    text: "保存设置";
                    primary: true;
                    width: 116px;
                    clicked => { root.save_frps(); }
                }
            }
        }
    }

    Timer {
        interval: 1600ms;
        running: root.save_feedback_visible;
        triggered => { root.save_feedback_visible = false; }
    }

    if root.save_feedback_visible : Rectangle {
        x: (parent.width - self.width) / 2;
        y: 20px;
        width: 142px;
        height: 38px;
        background: #166534;
        border-radius: 8px;

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            spacing: 7px;
            alignment: center;

            Rectangle {
                width: 18px;
                height: parent.height;
                background: transparent;

                Image {
                    x: 0px;
                    y: (parent.height - self.height) / 2;
                    width: 18px;
                    height: 18px;
                    source: @image-url("../../resources/icons/check.svg");
                }
            }
            Text {
                text: "设置已保存";
                color: #ffffff;
                font-size: 14px;
                font-weight: 800;
                vertical-alignment: center;
            }
        }
    }
}
